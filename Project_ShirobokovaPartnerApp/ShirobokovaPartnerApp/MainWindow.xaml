<Window x:Class="ShirobokovaPartnerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт партнёров - Система управления партнёрами (Широбокова А.М.)"
        Height="600" Width="1000"
        MinHeight="500" MinWidth="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Учёт партнёров компании" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Система управления партнёрской сетью" FontSize="12" Foreground="LightGray" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,5">
            <Button x:Name="BtnAdd" Content="➕ Добавить партнёра" Click="BtnAdd_Click" Background="#27AE60" Foreground="White"/>
            <Button x:Name="BtnRefresh" Content="🔄 Обновить" Click="BtnRefresh_Click" Background="#3498DB" Foreground="White"/>
        </StackPanel>

        <!-- Таблица партнёров -->
        <DataGrid x:Name="PartnersGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow"
                  RowHeaderWidth="0" Margin="0,5" AlternatingRowBackground="#F5F5F5"
                  MouseDoubleClick="PartnersGrid_MouseDoubleClick">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="✏️ Редактировать" Click="EditPartner_Click"/>
                    <MenuItem Header="📊 История продаж" Click="ShowSalesHistory_Click"/>
                    <MenuItem Header="❌ Удалить" Click="DeletePartner_Click"/>
                    <Separator/>
                    <MenuItem Header="🔄 Обновить список" Click="RefreshList_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Тип партнёра" Binding="{Binding PartnerType.Name}" Width="120"/>
                <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating}" Width="80"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Объём продаж (руб.)" Binding="{Binding TotalSales, StringFormat=N2}" Width="150"/>
                <DataGridTextColumn Header="Скидка (%)" Binding="{Binding DiscountPercent}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статусная строка -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="5" CornerRadius="3" Margin="0,5,0,0">
            <TextBlock x:Name="StatusText" Text="Готов к работе" Foreground="#2C3E50"/>
        </Border>
    </Grid>
</Window>