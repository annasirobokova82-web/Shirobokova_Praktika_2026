<Window x:Class="ShirobokovaPartnerApp.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование партнёра - Широбокова А.М."
        Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Данные партнёра" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <!-- Поля формы -->
        <Label Grid.Row="1" Grid.Column="0" Content="Наименование:" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="TxtName" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Тип партнёра:" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <ComboBox x:Name="CmbPartnerType" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" 
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Рейтинг:" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="TxtRating" Grid.Row="3" Grid.Column="1" Margin="5" Height="30" 
                 PreviewTextInput="NumberValidationTextBox" ToolTip="Целое неотрицательное число"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Адрес:" VerticalAlignment="Top" FontWeight="SemiBold"/>
        <TextBox x:Name="TxtAddress" Grid.Row="4" Grid.Column="1" Margin="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <Label Grid.Row="5" Grid.Column="0" Content="ФИО директора:" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="TxtDirectorName" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>

        <Label Grid.Row="6" Grid.Column="0" Content="Телефон:" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="TxtPhone" Grid.Row="6" Grid.Column="1" Margin="5" Height="30" 
                 ToolTip="Формат: +7 (XXX) XXX-XX-XX"/>

        <Label Grid.Row="7" Grid.Column="0" Content="Email:" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="TxtEmail" Grid.Row="7" Grid.Column="1" Margin="5" Height="30"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="BtnSave" Content="💾 Сохранить" Click="BtnSave_Click" Background="#27AE60" Foreground="White" Width="100" Height="35"/>
            <Button x:Name="BtnCancel" Content="❌ Отмена" Click="BtnCancel_Click" Background="#E74C3C" Foreground="White" Width="100" Height="35" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>